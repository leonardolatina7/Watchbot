# ═══════════════════════════════════════════════════
# Watch Price Bot v7 — DEFINITIVO
# Copia questo file in .env e compila i valori
# ═══════════════════════════════════════════════════

# ── EBAY API (gratis — developer.ebay.com) ──────────
EBAY_CLIENT_ID=tuo-client-id-qui
EBAY_CLIENT_SECRET=tuo-client-secret-qui

# ── YOUTUBE DATA API v3 (gratis — 10k req/giorno) ───
# console.cloud.google.com → Abilita "YouTube Data API v3"
# Senza questa chiave: funziona con scraping automatico
YOUTUBE_API_KEY=

# ── TELEGRAM BOT (NUOVO — notifiche push istantanee) ─
# 1. Apri Telegram → cerca @BotFather
# 2. Scrivi /newbot → dai un nome → copia il TOKEN
# 3. Cerca @userinfobot → ti dà il tuo CHAT_ID
# 4. Incolla qui sotto
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── PREZZO ORO LIVE (opzionale — metals-api.com) ────
# Gratis: 250 req/mese su metals-api.com
# Senza: usa goldprice.org come fallback automatico
METALS_API_KEY=

# ── EMAIL ALERT ──────────────────────────────────────
# App Password Gmail: myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tuaemail@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# ── SERVER ──────────────────────────────────────────
PORT=3001

# ── RENDER (compilato automaticamente da Render.com) ─
# Non modificare — usato per il webhook Telegram
# RENDER_EXTERNAL_URL=https://tuo-bot.onrender.com
